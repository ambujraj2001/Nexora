# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Mistral AI
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_KEY=your_mistral_api_key_here

# Axiom Logging
AXIOM_TOKEN=your_axiom_token_here
AXIOM_DATASET=your_axiom_dataset_here

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="chief of AI"

# LangChain Standard (for automatic tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="chief of AI"

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
SMTP_SENDER_EMAIL=your_verified_email_here
SMTP_SENDER_NAME="Chief of AI"

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Tavily API
TAVILY_API_KEY=your_tavily_api_key_here
